# Feature A — Adaptive Anomaly Detection (all optional; sane defaults in config.py)
AEGIS_REDIS_URL=redis://localhost:6379/0

# Risk-engine weights (sum to 1.0) and action thresholds
AEGIS_W_GLOBAL=0.3
AEGIS_W_PERKEY=0.3
AEGIS_W_ENUM=0.2
AEGIS_W_AUTH=0.2
AEGIS_T_LOG=0.5
AEGIS_T_TARPIT=0.7
AEGIS_T_BLOCK=0.9
AEGIS_TARPIT_SECONDS=2.0

# Poisoning guard: learn only from traffic scored below this
AEGIS_LEARN_GATE=0.5

# Score cache TTL (bounded staleness for fail-open) and worker heartbeat
AEGIS_RISK_TTL=60
AEGIS_HEARTBEAT_TTL=15

# Enumeration window (seconds) — 1 hour in prod; the evaluator overrides to 60
AEGIS_ENUM_WINDOW=3600
